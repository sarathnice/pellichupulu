{
  "name": "pellichupulu-v2-3-ai",
  "version": "2.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "db:migration:create": "wrangler d1 migrations create pellichupulu-v2",
    "db:migrate:local": "wrangler d1 migrations apply pellichupulu-v2 --local",
    "db:migrate:remote": "wrangler d1 migrations apply pellichupulu-v2 --remote",
    "deploy:pages": "wrangler pages deploy dist --project-name=pellichupulu",
    "deploy:worker": "wrangler deploy",
    "preview:worker": "wrangler dev"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "vite": "^5.0.0",
    "wrangler": "^4.83.0"
  }
}